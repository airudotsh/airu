{
  "name": "airu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck",
    "chat": "bun run --filter @airu/cli chat",
    "prepublishOnly": "bun run build && bun run typecheck && bun test"
  },
  "devDependencies": {
    "@airu/cli": "workspace:*",
    "@airu/core": "workspace:*",
    "@airu/plugins": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
